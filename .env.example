# Copy to .env and fill in your values.

# Required: OpenAI API key used by the default agent models and the embedder
# (the embedder stays on OpenAI even when the LLMs are flipped to Anthropic,
# since Anthropic doesn't ship embeddings).
OPENAI_API_KEY=sk-your-openai-key-here

# Required only when overriding any of the *_LLM env vars below to an
# `anthropic/...` model.
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Model used by the agents (see YAML configs; defaults to openai/gpt-5.4).
MODEL=gpt-5.4

# --- Per-role model overrides (no YAML edit needed) -------------------------
# Each one falls back to its agents.yaml default. To switch the whole stack to
# Anthropic Sonnet 4.6, set ANTHROPIC_API_KEY and point each var to
# `anthropic/claude-sonnet-4-6`.
# CODEBUILDER_PLANNER_LLM=openai/gpt-5.4
# CODEBUILDER_WRITER_LLM=openai/gpt-5.4
# CODEBUILDER_WRITER_REASONING=true   # set false for a faster but less careful writer
# CODEBUILDER_REVIEWER_LLM=openai/gpt-5.4-mini
# CODEBUILDER_QA_LLM=openai/gpt-5.4-mini
# CODEBUILDER_GUARDRAIL_LLM=openai/gpt-5.4-mini   # used by @human_feedback to classify replies

# --- Embedder (planner + QA memory) -----------------------------------------
# CODEBUILDER_EMBEDDER_PROVIDER=openai
# CODEBUILDER_EMBEDDER_MODEL=text-embedding-3-small

# Retry/repair controls. Subtask retries happen during the per-file build loop;
# final QA repairs happen once after whole-workspace lint/tests fail.
# CODEBUILDER_MAX_SUBTASK_RETRIES=1
# CODEBUILDER_MAX_FINAL_QA_REPAIRS=1

# Optional: override the workspace root (defaults to ./workspaces).
# CODEBUILDER_WORKSPACE_ROOT=./workspaces

# Optional: override the history SQLite DB path (defaults to ./data/codebuilder_history.db).
# CODEBUILDER_HISTORY_DB=./data/codebuilder_history.db

# Disable the project_history SQLite log (cross-run planner priors). Set to
# false on ephemeral runtimes where the local filesystem doesn't persist
# across invocations (e.g. CrewAI AMP). Planner falls back to crew memory only.
# CODEBUILDER_HISTORY_ENABLED=true

# --- Human-in-the-loop -------------------------------------------------------
# Webhook URL that WebhookFeedbackProvider POSTs to when a plan pauses for
# approval. When unset, the flow falls back to an interactive console prompt.
# For the codebuilder-web Flask frontend, set this to:
#   https://<codebuilder-web-host>/webhooks/feedback_ready
# CODEBUILDER_APPROVAL_WEBHOOK=https://example.com/hooks/approvals

# Optional progress webhook for frontend SSE updates after each subtask and
# final QA step. When unset, progress reporting is skipped.
# CODEBUILDER_PROGRESS_WEBHOOK=https://<codebuilder-web-host>/webhooks/progress
# CODEBUILDER_PROGRESS_WEBHOOK_SECRET=shared-secret

# --- Artifact upload (S3) ----------------------------------------------------
# When CODEBUILDER_ARTIFACT_BUCKET is set, finalize() uploads the build
# workspace to s3://<bucket>/<prefix>/<project_key>/<flow_id>/... and writes
# 7-day presigned GET URLs into QAReport.artifact_urls. Leave unset to skip
# uploads (local dev / tests).
# CODEBUILDER_ARTIFACT_BUCKET=crewai-fde

# Optional base prefix inside the bucket (useful for shared buckets).
# Example: "pedro/vivo-codebuilder" → objects land at
#   s3://crewai-fde/pedro/vivo-codebuilder/<project_key>/<flow_id>/...
# CODEBUILDER_ARTIFACT_PREFIX=pedro/vivo-codebuilder

# AWS credentials + region used for upload and presigned URL generation.
# The IAM user needs s3:PutObject + s3:GetObject on the prefix, e.g.:
#   "Resource": "arn:aws:s3:::crewai-fde/pedro/*"
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
