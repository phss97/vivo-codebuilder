# Copy to .env and fill in your values.

# Required: OpenAI API key used by all CrewAI agents.
OPENAI_API_KEY=sk-your-openai-key-here

# Model used by the agents (see YAML configs; defaults to openai/gpt-5.4).
MODEL=gpt-5.4

# Optional: override the workspace root (defaults to ./workspaces).
# CODEBUILDER_WORKSPACE_ROOT=./workspaces

# Optional: override the history SQLite DB path (defaults to ./data/codebuilder_history.db).
# CODEBUILDER_HISTORY_DB=./data/codebuilder_history.db

# Optional: webhook URL for human-in-the-loop plan approvals.
# When unset, the flow falls back to an interactive console prompt.
# CODEBUILDER_APPROVAL_WEBHOOK=https://example.com/hooks/approvals
